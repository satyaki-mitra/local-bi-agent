# =============================================================================
# LocalGenBI-Agent — Local (native Python) development environment
# =============================================================================
#
# Usage:
#   cp .env.local .env
#   Fill in every value marked  ← REQUIRED
#   Start Postgres, Ollama, gateway servers, and the app manually (see STARTUP_GUIDE.md)
#
# All services run on localhost with their default ports.
# =============================================================================
# Environment
ENVIRONMENT=development


# Ollama (LLM) — ollama serve must be running first
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b
OLLAMA_TEMPERATURE=0.0
OLLAMA_MAX_TOKENS=8192


# FastAPI backend
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8001
FASTAPI_WORKERS=1
FASTAPI_RELOAD=true


# Chainlit frontend
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8000
CHAINLIT_ALLOW_ORIGINS=http://localhost:8000
BACKEND_HOST=localhost
CHAINLIT_TEMP_EXPORT_DIR=/tmp/localgenbi_exports


# DB Gateway servers
GATEWAY_HEALTH_PORT=3001
GATEWAY_FINANCE_PORT=3002
GATEWAY_SALES_PORT=3003
GATEWAY_IOT_PORT=3004
DB_QUERY_TIMEOUT_SECONDS=60
DB_SCHEMA_TIMEOUT_SECONDS=10


# Database: Health
DB_HEALTH_HOST=localhost
DB_HEALTH_PORT=5432
DB_HEALTH_NAME=health_db
DB_HEALTH_USER=readonly_user
DB_HEALTH_PASSWORD=                # ← REQUIRED


# Database: Finance
DB_FINANCE_HOST=localhost
DB_FINANCE_PORT=5432
DB_FINANCE_NAME=finance_db
DB_FINANCE_USER=readonly_user
DB_FINANCE_PASSWORD=               # ← REQUIRED


# Database: Sales
DB_SALES_HOST=localhost
DB_SALES_PORT=5432
DB_SALES_NAME=sales_db
DB_SALES_USER=readonly_user
DB_SALES_PASSWORD=                 # ← REQUIRED


# Database: IoT
DB_IOT_HOST=localhost
DB_IOT_PORT=5432
DB_IOT_NAME=iot_db
DB_IOT_USER=readonly_user
DB_IOT_PASSWORD=                   # ← REQUIRED


DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=                 # ← REQUIRED


DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5
DB_POOL_MAX_INACTIVE_LIFETIME=60.0
DB_POOL_MAX_QUERIES=10000


# Security
ENABLE_PII_REDACTION=true
MAX_SQL_ROWS=10000
SQL_TIMEOUT_SECONDS=30
ALLOW_ONLY_SELECT=true


# Agent behaviour
MAX_AGENT_RETRIES=3
MAX_REASONING_STEPS=10
ENABLE_REASONING_TRACE=true
ANALYST_MAX_ROWS_IN_PROMPT=50
OUTLIER_DEFAULT_METHOD=iqr


# Rate limiting
RATE_LIMIT_QUERIES_PER_MINUTE=120
MAX_QUERY_LENGTH=1000


# Logging (verbose console format for local dev)
LOG_LEVEL=DEBUG
LOG_FORMAT=console
ENABLE_REQUEST_LOGGING=true


# Session history
SESSION_HISTORY_ENABLED=true
SESSION_HISTORY_MAX_TURNS=20
SESSION_CONTEXT_TURNS=5


# Cross-DB
ENABLE_CROSS_DB_JOINS=false
MAX_CROSS_DB_DOMAINS=2


# Exports
EXPORT_DIR=temp/exports
EXPORT_CLEANUP_DAYS=1
EXPORT_CLEANUP_INTERVAL_HOURS=1


# Visualization
ENABLE_VISUALIZATION=true
VIZ_DPI=100
VIZ_FIGURE_WIDTH=10.0
VIZ_FIGURE_HEIGHT=6.0


# Code execution sandbox
ENABLE_CODE_SANDBOX=true
CODE_EXECUTION_TIMEOUT=60
ALLOWED_IMPORTS=["pandas","numpy","matplotlib"]


# Evaluation
DEEPEVAL_ENABLED=false
DEEPEVAL_EVALUATOR_MODEL=ollama/deepseek-r1:8b
GOLDEN_DATASET_PATH=evaluation/golden_dataset.json